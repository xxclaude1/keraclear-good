<style>
  .kc-404 {
    max-width: 600px;
    margin: 0 auto;
    padding: 80px 20px;
    text-align: center;
  }
  .kc-404 h1 {
    font-family: var(--kc-font-heading);
    font-size: clamp(2rem, 5vw, 3rem);
    margin-bottom: 16px;
    color: var(--kc-teal);
  }
  .kc-404 p {
    font-size: 18px;
    color: var(--kc-gray);
    margin-bottom: 32px;
  }
  .kc-404 a {
    display: inline-flex;
    padding: 14px 32px;
    background: var(--kc-teal);
    color: #fff;
    border-radius: var(--kc-radius);
    font-weight: 600;
    text-decoration: none;
    transition: background 0.2s;
  }
  .kc-404 a:hover {
    background: var(--kc-teal-dark);
    color: #fff;
  }
</style>

<div class="kc-404">
  <h1>{{ section.settings.heading }}</h1>
  <p>{{ section.settings.text }}</p>
  <a href="/">{{ section.settings.button_text }}</a>
</div>

{% schema %}
{
  "name": "404 Page",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Page Not Found"
    },
    {
      "type": "text",
      "id": "text",
      "label": "Text",
      "default": "Sorry, the page you're looking for doesn't exist."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Back to Home"
    }
  ],
  "templates": ["404"]
}
{% endschema %}
