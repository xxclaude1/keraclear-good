{% style %}
  .kc-before-after {
    padding: 80px 20px;
    background: var(--kc-white, #FFFFFF);
  }

  .kc-before-after__inner {
    max-width: var(--kc-max-width, 1200px);
    margin: 0 auto;
  }

  .kc-before-after__heading {
    font-family: var(--kc-font-heading, 'Playfair Display', serif);
    font-size: 42px;
    font-weight: 700;
    color: var(--kc-black, #1A1A1A);
    text-align: center;
    margin: 0 0 16px 0;
    line-height: 1.2;
  }

  .kc-before-after__subheading {
    font-family: var(--kc-font-body, 'Inter', sans-serif);
    font-size: 18px;
    font-weight: 400;
    color: var(--kc-gray, #6B7280);
    text-align: center;
    margin: 0 auto 56px auto;
    max-width: 640px;
    line-height: 1.6;
  }

  .kc-before-after__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }

  .kc-before-after__card {
    background: var(--kc-white, #FFFFFF);
    border: 1px solid #E5E7EB;
    border-radius: var(--kc-radius, 12px);
    overflow: hidden;
    box-shadow: var(--kc-shadow, 0 4px 24px rgba(13, 115, 119, 0.08));
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .kc-before-after__card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 32px rgba(13, 115, 119, 0.12);
  }

  .kc-before-after__images {
    display: grid;
    grid-template-columns: 1fr 1fr;
  }

  .kc-before-after__image-col {
    position: relative;
    overflow: hidden;
  }

  .kc-before-after__image-col img {
    width: 100%;
    height: 220px;
    object-fit: cover;
    display: block;
  }

  .kc-before-after__placeholder {
    width: 100%;
    height: 220px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--kc-font-body, 'Inter', sans-serif);
    font-size: 14px;
    font-weight: 500;
    color: var(--kc-gray, #6B7280);
  }

  .kc-before-after__image-col--before .kc-before-after__placeholder {
    background: #F3F4F6;
  }

  .kc-before-after__image-col--after .kc-before-after__placeholder {
    background: var(--kc-teal-light, #E8F4F4);
  }

  .kc-before-after__label {
    position: absolute;
    top: 12px;
    left: 12px;
    font-family: var(--kc-font-body, 'Inter', sans-serif);
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 4px 10px;
    border-radius: 6px;
    line-height: 1.3;
  }

  .kc-before-after__image-col--before .kc-before-after__label {
    background: rgba(26, 26, 26, 0.75);
    color: var(--kc-white, #FFFFFF);
  }

  .kc-before-after__image-col--after .kc-before-after__label {
    background: rgba(13, 115, 119, 0.85);
    color: var(--kc-white, #FFFFFF);
  }

  .kc-before-after__divider {
    width: 2px;
    background: var(--kc-white, #FFFFFF);
    position: absolute;
    top: 0;
    bottom: 0;
    right: 0;
    z-index: 1;
  }

  .kc-before-after__info {
    padding: 24px 24px;
    text-align: center;
  }

  .kc-before-after__caption {
    font-family: var(--kc-font-heading, 'Playfair Display', serif);
    font-size: 18px;
    font-weight: 600;
    color: var(--kc-black, #1A1A1A);
    margin: 0 0 6px 0;
    line-height: 1.3;
  }

  .kc-before-after__timeline {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--kc-font-body, 'Inter', sans-serif);
    font-size: 14px;
    font-weight: 600;
    color: var(--kc-teal, #0D7377);
    margin: 0;
    line-height: 1.4;
  }

  .kc-before-after__timeline svg {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  .kc-before-after__disclaimer {
    font-family: var(--kc-font-body, 'Inter', sans-serif);
    font-size: 13px;
    font-weight: 400;
    color: #9CA3AF;
    text-align: center;
    margin: 40px auto 0 auto;
    max-width: 600px;
    line-height: 1.6;
  }

  @media (max-width: 900px) {
    .kc-before-after__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 24px;
    }
  }

  @media (max-width: 600px) {
    .kc-before-after {
      padding: 56px 16px;
    }

    .kc-before-after__heading {
      font-size: 30px;
      margin-bottom: 12px;
    }

    .kc-before-after__subheading {
      font-size: 16px;
      margin-bottom: 40px;
    }

    .kc-before-after__grid {
      grid-template-columns: 1fr;
      gap: 20px;
    }

    .kc-before-after__image-col img,
    .kc-before-after__placeholder {
      height: 180px;
    }

    .kc-before-after__info {
      padding: 20px 20px;
    }

    .kc-before-after__disclaimer {
      font-size: 12px;
      margin-top: 32px;
    }
  }
{% endstyle %}

<section class="kc-before-after" id="before-after">
  <div class="kc-before-after__inner">
    {% if section.settings.heading != blank %}
      <h2 class="kc-before-after__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    {% if section.settings.subheading != blank %}
      <p class="kc-before-after__subheading">{{ section.settings.subheading }}</p>
    {% endif %}

    {% if section.blocks.size > 0 %}
      <div class="kc-before-after__grid">
        {% for block in section.blocks %}
          <div class="kc-before-after__card" {{ block.shopify_attributes }}>
            <div class="kc-before-after__images">
              <div class="kc-before-after__image-col kc-before-after__image-col--before">
                <span class="kc-before-after__label">Before</span>
                <div class="kc-before-after__divider"></div>
                {%- if block.settings.before_image != blank -%}
                  <img
                    src="{{ block.settings.before_image | image_url: width: 600 }}"
                    alt="Before - {{ block.settings.caption | escape }}"
                    width="300"
                    height="220"
                    loading="lazy"
                  >
                {%- else -%}
                  <div class="kc-before-after__placeholder">Before photo</div>
                {%- endif -%}
              </div>
              <div class="kc-before-after__image-col kc-before-after__image-col--after">
                <span class="kc-before-after__label">After</span>
                {%- if block.settings.after_image != blank -%}
                  <img
                    src="{{ block.settings.after_image | image_url: width: 600 }}"
                    alt="After - {{ block.settings.caption | escape }}"
                    width="300"
                    height="220"
                    loading="lazy"
                  >
                {%- else -%}
                  <div class="kc-before-after__placeholder">After photo</div>
                {%- endif -%}
              </div>
            </div>

            <div class="kc-before-after__info">
              {%- if block.settings.caption != blank -%}
                <p class="kc-before-after__caption">{{ block.settings.caption }}</p>
              {%- endif -%}
              {%- if block.settings.timeline != blank -%}
                <p class="kc-before-after__timeline">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                  {{ block.settings.timeline }}
                </p>
              {%- endif -%}
            </div>
          </div>
        {% endfor %}
      </div>
    {% endif %}

    {% if section.settings.disclaimer != blank %}
      <p class="kc-before-after__disclaimer">{{ section.settings.disclaimer }}</p>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "KC Before & After",
  "tag": "section",
  "class": "kc-before-after-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "See the Transformation"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Section Subheading",
      "default": "Real results from real customers using KeraClear daily."
    },
    {
      "type": "textarea",
      "id": "disclaimer",
      "label": "Disclaimer Text",
      "default": "*Individual results may vary. Photos submitted by verified customers. KeraClear recommends consistent daily use for optimal results."
    }
  ],
  "blocks": [
    {
      "type": "comparison",
      "name": "Before/After Pair",
      "settings": [
        {
          "type": "image_picker",
          "id": "before_image",
          "label": "Before Image"
        },
        {
          "type": "image_picker",
          "id": "after_image",
          "label": "After Image"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Caption / Name",
          "default": "Customer Name"
        },
        {
          "type": "text",
          "id": "timeline",
          "label": "Timeline",
          "default": "After 90 days"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "KC Before & After",
      "settings": {
        "heading": "See the Transformation",
        "subheading": "Real results from real customers using KeraClear daily.",
        "disclaimer": "*Individual results may vary. Photos submitted by verified customers. KeraClear recommends consistent daily use for optimal results."
      },
      "blocks": [
        {
          "type": "comparison",
          "settings": {
            "caption": "Robert, 58",
            "timeline": "After 90 days"
          }
        },
        {
          "type": "comparison",
          "settings": {
            "caption": "Patricia, 45",
            "timeline": "After 60 days"
          }
        },
        {
          "type": "comparison",
          "settings": {
            "caption": "Sandra, 52",
            "timeline": "After 120 days"
          }
        }
      ]
    }
  ]
}
{% endschema %}
