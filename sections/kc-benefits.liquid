{{ 'https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Inter:wght@400;500;600&display=swap' | stylesheet_tag }}

{% style %}
  :root {
    --kc-teal: #0D7377;
    --kc-teal-dark: #095456;
    --kc-teal-light: #E8F4F4;
    --kc-gold: #C8A951;
    --kc-gold-light: #F5EDD6;
    --kc-white: #FFFFFF;
    --kc-black: #1A1A1A;
    --kc-gray: #6B7280;
    --kc-font-heading: 'Playfair Display', serif;
    --kc-font-body: 'Inter', sans-serif;
    --kc-radius: 12px;
    --kc-shadow: 0 4px 24px rgba(13, 115, 119, 0.08);
    --kc-max-width: 1200px;
  }

  .kc-benefits {
    padding: 80px 20px;
    background: var(--kc-white);
  }

  .kc-benefits__inner {
    max-width: var(--kc-max-width);
    margin: 0 auto;
  }

  .kc-benefits__heading {
    font-family: var(--kc-font-heading);
    font-size: 42px;
    font-weight: 700;
    color: var(--kc-black);
    text-align: center;
    margin: 0 0 16px 0;
    line-height: 1.2;
  }

  .kc-benefits__heading em {
    color: var(--kc-teal);
    font-style: normal;
  }

  .kc-benefits__subheading {
    font-family: var(--kc-font-body);
    font-size: 18px;
    font-weight: 400;
    color: var(--kc-gray);
    text-align: center;
    margin: 0 auto 56px auto;
    max-width: 640px;
    line-height: 1.6;
  }

  .kc-benefits__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 28px;
  }

  .kc-benefits__card {
    background: var(--kc-white);
    border: 1px solid #E5E7EB;
    border-radius: var(--kc-radius);
    padding: 40px 32px;
    box-shadow: var(--kc-shadow);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    position: relative;
    overflow: hidden;
  }

  .kc-benefits__card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--kc-teal), var(--kc-gold));
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .kc-benefits__card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 32px rgba(13, 115, 119, 0.12);
  }

  .kc-benefits__card:hover::before {
    opacity: 1;
  }

  .kc-benefits__icon {
    width: 64px;
    height: 64px;
    border-radius: 16px;
    background: var(--kc-teal-light);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 24px;
    font-size: 28px;
    line-height: 1;
  }

  .kc-benefits__icon img {
    width: 36px;
    height: 36px;
    object-fit: contain;
  }

  .kc-benefits__card-title {
    font-family: var(--kc-font-heading);
    font-size: 22px;
    font-weight: 600;
    color: var(--kc-black);
    margin: 0 0 12px 0;
    line-height: 1.3;
  }

  .kc-benefits__card-desc {
    font-family: var(--kc-font-body);
    font-size: 15px;
    font-weight: 400;
    color: var(--kc-gray);
    margin: 0;
    line-height: 1.7;
  }

  @media (max-width: 768px) {
    .kc-benefits {
      padding: 56px 16px;
    }

    .kc-benefits__heading {
      font-size: 30px;
    }

    .kc-benefits__subheading {
      font-size: 16px;
      margin-bottom: 40px;
    }

    .kc-benefits__grid {
      grid-template-columns: 1fr;
      gap: 20px;
    }

    .kc-benefits__card {
      padding: 32px 24px;
    }

    .kc-benefits__card-title {
      font-size: 20px;
    }
  }
{% endstyle %}

<section class="kc-benefits" id="benefits">
  <div class="kc-benefits__inner">
    {% if section.settings.heading != blank %}
      <h2 class="kc-benefits__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    {% if section.settings.subheading != blank %}
      <p class="kc-benefits__subheading">{{ section.settings.subheading }}</p>
    {% endif %}

    <div class="kc-benefits__grid">
      {% for block in section.blocks %}
        <div class="kc-benefits__card" {{ block.shopify_attributes }}>
          <div class="kc-benefits__icon">
            {% if block.settings.icon_image != blank %}
              <img
                src="{{ block.settings.icon_image | image_url: width: 72 }}"
                alt="{{ block.settings.title | escape }}"
                width="36"
                height="36"
                loading="lazy"
              >
            {% else %}
              <span>{{ block.settings.icon_emoji }}</span>
            {% endif %}
          </div>

          {% if block.settings.title != blank %}
            <h3 class="kc-benefits__card-title">{{ block.settings.title }}</h3>
          {% endif %}

          {% if block.settings.description != blank %}
            <p class="kc-benefits__card-desc">{{ block.settings.description }}</p>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "KC Benefits",
  "tag": "section",
  "class": "kc-benefits-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Why KeraClear Works When Others Don't"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Section Subheading",
      "default": "Backed by science, powered by nature — our formula targets nail fungus at the source."
    }
  ],
  "blocks": [
    {
      "type": "benefit_card",
      "name": "Benefit Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Icon Image",
          "info": "Upload a custom icon. If empty, the emoji below will be used."
        },
        {
          "type": "text",
          "id": "icon_emoji",
          "label": "Icon Emoji",
          "default": "🔬",
          "info": "Fallback emoji if no icon image is uploaded."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Card Title",
          "default": "Benefit Title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Card Description",
          "default": "Describe this benefit for your customers."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "KC Benefits",
      "blocks": [
        {
          "type": "benefit_card",
          "settings": {
            "icon_emoji": "🔬",
            "title": "Biofilm Penetration Technology",
            "description": "Our proprietary formula breaks through the protective biofilm barrier that blocks 99% of other treatments from reaching the fungus."
          }
        },
        {
          "type": "benefit_card",
          "settings": {
            "icon_emoji": "💧",
            "title": "Deep Nail Bed Delivery",
            "description": "Unlike surface creams, KeraClear's oil-based formula penetrates through the nail plate to deliver antifungal agents directly where fungus lives."
          }
        },
        {
          "type": "benefit_card",
          "settings": {
            "icon_emoji": "🌿",
            "title": "Natural, Safe Ingredients",
            "description": "Formulated with clinically-studied natural compounds including tea tree oil, undecylenic acid, and vitamin E. No harsh chemicals or side effects."
          }
        },
        {
          "type": "benefit_card",
          "settings": {
            "icon_emoji": "⏱️",
            "title": "Visible Results in 4-6 Weeks",
            "description": "Most users see noticeable improvement within the first month. Clear nail growth becomes visible as early as 4-6 weeks."
          }
        }
      ]
    }
  ]
}
{% endschema %}
