{{ 'https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Inter:wght@400;500;600&display=swap' | stylesheet_tag }}

{% style %}
  :root {
    --kc-teal: #0D7377;
    --kc-teal-dark: #095456;
    --kc-teal-light: #E6F3F3;
    --kc-gold: #C8A951;
    --kc-gold-light: #F5EDDA;
    --kc-white: #FFFFFF;
    --kc-black: #1A1A1A;
    --kc-gray: #6B7280;
    --kc-font-heading: 'Playfair Display', serif;
    --kc-font-body: 'Inter', sans-serif;
    --kc-radius: 12px;
    --kc-shadow: 0 4px 24px rgba(0, 0, 0, 0.08);
    --kc-max-width: 1200px;
  }

  .kc-ingredients {
    padding: 80px 20px;
    background: var(--kc-teal-light);
  }

  .kc-ingredients__inner {
    max-width: var(--kc-max-width);
    margin: 0 auto;
  }

  .kc-ingredients__header {
    text-align: center;
    margin-bottom: 64px;
  }

  .kc-ingredients__heading {
    font-family: var(--kc-font-heading);
    font-size: 42px;
    font-weight: 700;
    color: var(--kc-black);
    margin: 0 0 16px 0;
    line-height: 1.2;
  }

  .kc-ingredients__subheading {
    font-family: var(--kc-font-body);
    font-size: 18px;
    font-weight: 400;
    color: var(--kc-gray);
    margin: 0;
    line-height: 1.6;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .kc-ingredients__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 28px;
  }

  .kc-ingredients__card {
    background: var(--kc-white);
    border-radius: var(--kc-radius);
    box-shadow: var(--kc-shadow);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .kc-ingredients__card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.12);
  }

  .kc-ingredients__card-image {
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: linear-gradient(135deg, var(--kc-teal-light) 0%, #d4ecec 100%);
  }

  .kc-ingredients__card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .kc-ingredients__card-image--placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .kc-ingredients__card-image--placeholder svg {
    width: 48px;
    height: 48px;
    opacity: 0.25;
  }

  .kc-ingredients__card-body {
    padding: 28px 24px;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }

  .kc-ingredients__card-name {
    font-family: var(--kc-font-heading);
    font-size: 20px;
    font-weight: 600;
    color: var(--kc-teal-dark);
    margin: 0 0 12px 0;
    line-height: 1.3;
  }

  .kc-ingredients__card-desc {
    font-family: var(--kc-font-body);
    font-size: 14px;
    font-weight: 400;
    color: var(--kc-gray);
    margin: 0;
    line-height: 1.7;
    flex-grow: 1;
  }

  /* Tablet: 2x2 grid */
  @media (max-width: 1024px) {
    .kc-ingredients__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 24px;
    }
  }

  @media (max-width: 900px) {
    .kc-ingredients__heading {
      font-size: 34px;
    }

    .kc-ingredients__subheading {
      font-size: 16px;
    }

    .kc-ingredients {
      padding: 60px 20px;
    }

    .kc-ingredients__header {
      margin-bottom: 48px;
    }
  }

  /* Mobile: stacked single column */
  @media (max-width: 600px) {
    .kc-ingredients__grid {
      grid-template-columns: 1fr;
      gap: 20px;
      max-width: 400px;
      margin: 0 auto;
    }

    .kc-ingredients__heading {
      font-size: 28px;
    }

    .kc-ingredients__card-body {
      padding: 24px 20px;
    }

    .kc-ingredients__card-name {
      font-size: 18px;
    }

    .kc-ingredients {
      padding: 48px 16px;
    }
  }
{% endstyle %}

<section id="ingredients" class="kc-ingredients" data-section-id="{{ section.id }}">
  <div class="kc-ingredients__inner">
    <div class="kc-ingredients__header">
      {% if section.settings.heading != blank %}
        <h2 class="kc-ingredients__heading">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.subheading != blank %}
        <p class="kc-ingredients__subheading">{{ section.settings.subheading }}</p>
      {% endif %}
    </div>

    <div class="kc-ingredients__grid">
      {% for block in section.blocks %}
        <div class="kc-ingredients__card" {{ block.shopify_attributes }}>
          {% if block.settings.image != blank %}
            <div class="kc-ingredients__card-image">
              {{ block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy', alt: block.settings.name }}
            </div>
          {% else %}
            <div class="kc-ingredients__card-image kc-ingredients__card-image--placeholder">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 2L2 7l10 5 10-5-10-5z"/>
                <path d="M2 17l10 5 10-5"/>
                <path d="M2 12l10 5 10-5"/>
              </svg>
            </div>
          {% endif %}

          <div class="kc-ingredients__card-body">
            {% if block.settings.name != blank %}
              <h3 class="kc-ingredients__card-name">{{ block.settings.name }}</h3>
            {% endif %}
            {% if block.settings.description != blank %}
              <p class="kc-ingredients__card-desc">{{ block.settings.description }}</p>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "KC - Ingredients",
  "tag": "section",
  "class": "kc-section-ingredients",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Clinically-Studied Ingredients"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Every ingredient backed by science, selected by a dermatologist"
    }
  ],
  "blocks": [
    {
      "type": "ingredient",
      "name": "Ingredient",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Ingredient Image"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Ingredient Name",
          "default": "Ingredient Name"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Describe the ingredient and its benefits."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "KC - Ingredients",
      "blocks": [
        {
          "type": "ingredient",
          "settings": {
            "name": "Undecylenic Acid",
            "description": "FDA-recognized antifungal compound that disrupts fungal cell membranes. The primary active ingredient in KeraClear."
          }
        },
        {
          "type": "ingredient",
          "settings": {
            "name": "Tea Tree Oil",
            "description": "Powerful natural antifungal and antiseptic. Clinical studies show it's as effective as clotrimazole for treating nail fungus."
          }
        },
        {
          "type": "ingredient",
          "settings": {
            "name": "Vitamin E",
            "description": "Nourishes and strengthens damaged nail beds while supporting healthy new nail growth. A powerful antioxidant for tissue repair."
          }
        },
        {
          "type": "ingredient",
          "settings": {
            "name": "Jojoba Oil",
            "description": "Carrier oil that enhances absorption and penetration. Its molecular structure closely mimics natural skin oils for maximum delivery."
          }
        }
      ]
    }
  ]
}
{% endschema %}
