          "default": "Add to Cart"
        },
        {
          "type": "url",
          "id": "button_url",
          "label": "Button link",
          "info": "Link to the cart add URL for this variant, e.g. /cart/add?id=VARIANT_ID"
        },
        {
          "type": "checkbox",
          "id": "is_featured",
          "label": "Featured tier (visually elevated)",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "KC Pricing",
      "blocks": [
        {
          "type": "pricing_tier",
          "settings": {
            "badge": "STARTER",
            "title": "2 Bottles",
            "subtitle": "60 Day Supply",
            "price": "$158",
            "compare_at_price": "$358",
            "per_bottle_price": "$79/bottle",
            "savings": "Save $200",
            "features": "Free shipping\n90-day guarantee\nFull treatment guide",
            "button_text": "Add to Cart",
            "is_featured": false
          }
        },
        {
          "type": "pricing_tier",
          "settings": {
            "badge": "MOST POPULAR",
            "title": "3 Bottles",
            "subtitle": "90 Day Supply",
            "price": "$207",
            "compare_at_price": "$537",
            "per_bottle_price": "$69/bottle",
            "savings": "Save $330",
            "features": "Free shipping\n90-day guarantee\nFull treatment guide\nPriority support",
            "button_text": "Add to Cart — Best Value",
            "is_featured": true
          }
        },
        {
          "type": "pricing_tier",
          "settings": {
            "badge": "BEST VALUE",
            "title": "6 Bottles",
            "subtitle": "180 Day Supply",
            "price": "$294",
            "compare_at_price": "$1,074",
            "per_bottle_price": "$49/bottle",
            "savings": "Save $780",
            "features": "Free shipping\n90-day guarantee\nFull treatment guide\nPriority support\nFree nail care kit",
            "button_text": "Add to Cart — Maximum Savings",
            "is_featured": false
          }
        }
      ]
