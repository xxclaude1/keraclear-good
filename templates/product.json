    "faq": {
      "type": "kc-faq",
      "blocks": {
        "faq-1": {
          "type": "faq",
          "settings": {
            "question": "How long does it take to see results?",
            "answer": "Most customers report visible improvement within 4-8 weeks of consistent use. For best results, we recommend the full 90-day treatment cycle. Nails grow slowly, so patience and consistency are key."
          }
        },
        "faq-2": {
          "type": "faq",
          "settings": {
            "question": "What ingredients are in Keraclear?",
            "answer": "Keraclear contains Tea Tree Oil, Undecylenic Acid, Vitamin E, and Jojoba Oil — all natural, clinically-studied ingredients selected by Dr. Landford for their proven antifungal and nail-nourishing properties."
          }
        },
        "faq-3": {
          "type": "faq",
          "settings": {
            "question": "How do I use Keraclear?",
            "answer": "Apply 2-3 drops directly to each affected nail twice daily. Clean and dry the nail(s) first, apply the serum, and allow 1-2 minutes for absorption. The oil formula absorbs quickly with no residue."
          }
        },
        "faq-4": {
          "type": "faq",
          "settings": {
            "question": "Is Keraclear safe to use?",
            "answer": "Yes. Keraclear is made with natural, clinically-studied ingredients. It contains no harsh chemicals, parabens, or artificial fragrances. As with any product, consult your healthcare provider if you have concerns."
          }
        },
        "faq-5": {
          "type": "faq",
          "settings": {
            "question": "Can I use it on fingernails too?",
            "answer": "Yes, Keraclear works on both fingernails and toenails. The formula is designed to penetrate through any nail bed to reach the fungus at its source."
          }
        },
        "faq-6": {
          "type": "faq",
          "settings": {
            "question": "When will I notice results?",
            "answer": "Most users see improvements in nail clarity within 4-6 weeks. Full results are typically visible by 90 days. The 6-bottle package is our most popular because it covers a complete treatment cycle."
          }
        },
        "faq-7": {
          "type": "faq",
          "settings": {
            "question": "Is Keraclear safe to take with my current medications?",
            "answer": "Keraclear is a topical treatment applied directly to the nail. It does not interact with oral medications. However, if you have specific concerns, we always recommend consulting with your healthcare provider."
          }
        }
